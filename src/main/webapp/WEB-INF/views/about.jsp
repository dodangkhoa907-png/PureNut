            <!-- Book Spread -->
            <style>
            /* ===== Sách 3D — tông giấy kem mộc mạc + chân thực hơn (chỉ #vi-sao) ===== */
            #vi-sao{background:linear-gradient(180deg,#F3ECDD,#EAE0CA) !important}
            #vi-sao .h2{color:#4A3B23 !important}
            #vi-sao .h2 em{color:#B9883A !important}
            #vi-sao .eyebrow{color:#7A5A2A !important}
            #vi-sao .section-desc{color:#7A674A !important}
            #vi-sao .pn-book-wrap{position:relative;overflow:visible;padding:34px 14px 22px}
            #vi-sao .pn-book{position:relative;background:transparent !important}
            /* Bìa cứng nhô ra ngoài mép trang */
            #vi-sao .pn-book::before{content:"";position:absolute;inset:-15px -19px;border-radius:20px;background:linear-gradient(135deg,#C08536,#6E4A17);box-shadow:0 36px 70px -28px rgba(70,45,15,.6),inset 0 1px 0 rgba(255,255,255,.15);z-index:-2}
            /* Mép chồng nhiều trang (chiều sâu giấy) */
            #vi-sao .pn-book::after{content:"";position:absolute;top:9px;bottom:9px;right:-5px;width:13px;border-radius:0 8px 8px 0;background:repeating-linear-gradient(90deg,#F3EAD6,#F3EAD6 1px,#DCC9A0 1px,#DCC9A0 3px);box-shadow:2px 0 7px rgba(0,0,0,.14);z-index:-1}
            /* Trang giấy kem, chữ nâu/rêu */
            #vi-sao .pn-page-left,#vi-sao .pn-page-right,#vi-sao .pn-face{background:#FCF6E7 !important;border:none !important}
            #vi-sao .pn-page-right{box-shadow:inset 26px 0 32px -26px rgba(95,65,25,.5) !important}
            #vi-sao .pn-page-left{box-shadow:inset -26px 0 32px -26px rgba(95,65,25,.5) !important}
            #vi-sao .pn-page-inner{color:#6E5C3E !important;text-align:left !important;align-items:flex-start !important}
            #vi-sao .pn-page-inner h3{color:#3B5D3B !important}
            #vi-sao .pn-page-inner p{color:#7A674A !important}
            #vi-sao .pn-page-inner .pn-card-tag{color:#B9883A !important}
            #vi-sao .pn-page-inner .pn-card-divider{background:#B9883A !important}
            /* Bìa + bìa cuối căn giữa, chữ nâu đậm */
            #vi-sao .pn-cover-inner{text-align:center !important;align-items:center !important}
            #vi-sao .pn-cover-inner h3{color:#4A3B23 !important}
