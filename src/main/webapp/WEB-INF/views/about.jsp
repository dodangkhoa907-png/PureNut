                var i = this.current;

                // Left page
                lEl.className = '';
                if (i === 0) {
                  lEl.innerHTML = this.coverHTML();
                } else {
                  lEl.innerHTML = this.cardHTML(this.data[i - 1]);
                }
                lEl.className = dir === 'prev' ? 'pn-anim-right' : (dir === 'next' ? 'pn-anim-fade' : '');

                // Right page
                rEl.className = '';
                rEl.innerHTML = this.cardHTML(this.data[i]);
                if (dir) {
                  void rEl.offsetWidth; // force reflow
                  rEl.className = dir === 'next' ? 'pn-anim-right' : 'pn-anim-left';
                }

                // Buttons
                prev.disabled = (i === 0);
                next.disabled = (i === this.data.length - 1);

                // Dots
                var dots = document.querySelectorAll('.pn-dot');
                for (var k = 0; k < dots.length; k++) {
                  dots[k].classList.toggle('active', k === i);
                }
