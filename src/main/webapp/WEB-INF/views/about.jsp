                      '<span style="width:28px;height:28px;border-radius:50%;background:' + d.color + '33;color:' + d.color + ';display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;flex-shrink:0">' + (i + 1) + '</span>' +
                      '<span style="font-weight:600">' + t + '</span></div>';
                  }).join('');
                  return '<div class="pn-page-inner">' + head('Mục lục', d.color) +
                    '<h3 style="margin-bottom:4px">' + d.title + '</h3>' +
