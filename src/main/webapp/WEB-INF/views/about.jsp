              },
              prev: function () {
                if (this.current > 0) { this.current--; this.render('prev'); }
              },

              init: function () {
                var self = this;
                // Build dots
                var dotsWrap = document.getElementById('pnDots');
                for (var i = 0; i < this.data.length; i++) {
                  (function (idx) {
                    var dot = document.createElement('div');
                    dot.className = 'pn-dot' + (idx === 0 ? ' active' : '');
                    dot.addEventListener('click', function () { self.current = idx; self.render(null); });
                    dotsWrap.appendChild(dot);
                  })(i);
                }

                document.getElementById('pnPrevBtn').addEventListener('click', function () { self.prev(); });
                document.getElementById('pnNextBtn').addEventListener('click', function () { self.next(); });

                // Keyboard
                document.addEventListener('keydown', function (e) {
                  if (e.key === 'ArrowRight') self.next();
                  if (e.key === 'ArrowLeft') self.prev();
                });

