      <!-- ===== TOC RAIL: mục lục nổi bên trái (tự chứa, tiền tố toc-) ===== -->
      <style>
        .toc-rail{position:fixed;left:18px;top:50%;transform:translateY(-50%);z-index:90;display:flex;flex-direction:column;gap:10px;opacity:.2;transition:opacity .35s ease}
        .toc-rail:hover{opacity:1}
        .toc-item{display:flex;align-items:center;gap:0;background:#FFFDF8;border:1px solid rgba(36,31,24,.12);border-radius:99px;padding:9px;box-shadow:0 10px 26px -14px rgba(20,30,20,.35);color:#6B6357;text-decoration:none;max-width:44px;overflow:hidden;white-space:nowrap;transition:max-width .4s cubic-bezier(.2,.7,.2,1),background .25s,color .25s,transform .25s}
        .toc-item .toc-ic{width:26px;height:26px;display:flex;align-items:center;justify-content:center;font-size:15px;flex:none}
        .toc-item .toc-lb{font-family:'Inter',sans-serif;font-weight:700;font-size:12.5px;line-height:1.25;margin:0 12px 0 6px;opacity:0;transition:opacity .3s .08s}
        .toc-item .toc-lb small{display:block;font-weight:600;font-size:10.5px;opacity:.72}
        .toc-rail:hover .toc-item{max-width:240px}
        .toc-rail:hover .toc-lb{opacity:1}
        .toc-item:hover{background:#1B4F9E;color:#fff;transform:translateX(4px)}
        .toc-item.toc-on{background:#1B4F9E;color:#fff;border-color:#1B4F9E}
        @media(max-width:900px){.toc-rail{display:none}}
      </style>
      <nav class="toc-rail" id="tocRail" aria-label="Mục lục trang">
        <a class="toc-item" href="#hero"><span class="toc-ic">🏠</span><span class="toc-lb">Đầu trang<small>Giới thiệu PureNut</small></span></a>
        <a class="toc-item" href="#vi-sao-sua-hat"><span class="toc-ic">🌱</span><span class="toc-lb">Vì sao chọn<small>sữa hạt</small></span></a>
        <a class="toc-item" href="#bao-bi"><span class="toc-ic">📦</span><span class="toc-lb">Chi tiết sản phẩm<small>bao bì</small></span></a>
        <a class="toc-item" href="#vi-sao"><span class="toc-ic">📖</span><span class="toc-lb">Vì sao PureNut<small>câu chuyện</small></span></a>
        <a class="toc-item" href="#lien-he"><span class="toc-ic">✉️</span><span class="toc-lb">Liên hệ<small>hợp tác đại lý</small></span></a>
      </nav>
      <script>
        (function(){
          var rail=document.getElementById('tocRail'); if(!rail) return;
          var items=rail.querySelectorAll('.toc-item');
          var map={};
          items.forEach(function(a){var id=a.getAttribute('href').slice(1);var el=document.getElementById(id);if(el)map[id]=a;});
          var io=new IntersectionObserver(function(es){
            es.forEach(function(e){ if(e.isIntersecting){ items.forEach(function(a){a.classList.remove('toc-on');}); var a=map[e.target.id]; if(a)a.classList.add('toc-on'); } });
          },{rootMargin:'-38% 0px -55% 0px'});
          Object.keys(map).forEach(function(id){io.observe(document.getElementById(id));});
        })();
