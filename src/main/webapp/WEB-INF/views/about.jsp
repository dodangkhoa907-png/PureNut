            /* Gáy sách: dải bóng mềm uốn cong, bỏ đường kẻ sắc */
            #vi-sao .pn-spine{width:48px !important;background:linear-gradient(90deg,rgba(70,45,15,0),rgba(70,45,15,.13) 42%,rgba(70,45,15,.26) 50%,rgba(70,45,15,.13) 58%,rgba(70,45,15,0)) !important;box-shadow:none !important;border:none !important}
